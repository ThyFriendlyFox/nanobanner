# Set this to enable the "AI (Nano Banana)" adjustment mode in the UI.
# When set, a Standard / AI switch is shown; when not set, the switch is hidden.
# Use a Google AI (Gemini) API key from https://aistudio.google.com/apikey
# NANO_BANANA_API_KEY=your-api-key-here

# Optional: override the Gemini model used for image reframing (default: gemini-3.1-flash-preview)
# NANO_BANANA_MODEL=gemini-3.1-flash-image-preview
